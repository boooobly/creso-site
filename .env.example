# Required database connection string for Prisma
DATABASE_URL=

# Base public URL of the app (required in production)
PUBLIC_BASE_URL=http://localhost:3000

# Required token used by admin review moderation API routes
ADMIN_TOKEN=

# Required recipient email address for incoming request notifications
MAIL_TO=

# Send customer order emails (true/false). Defaults to false when omitted.
SEND_CUSTOMER_EMAILS=false

# Optional Telegram integration (set both values together)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional SMTP configuration (required when SEND_CUSTOMER_EMAILS=true)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Optional sender/recipient addresses for specific email flows
LEADS_TO_EMAIL=
LEADS_FROM_EMAIL=

# Optional content CMS credentials
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=

# Optional legacy moderation token
REVIEW_MODERATION_TOKEN=

# Optional secret for signed order PDF access tokens (falls back to ADMIN_TOKEN when omitted)
ORDER_TOKEN_SECRET=

# Secret used to verify /api/payments/webhook signatures
PAYMENT_WEBHOOK_SECRET=
