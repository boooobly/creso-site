# Toggle database-backed features (Prisma routes). When true, DATABASE_URL is required.
ENABLE_DATABASE=false

# Prisma database connection string (required only when ENABLE_DATABASE=true)
DATABASE_URL=

# Base public URL of the app (required in production)
PUBLIC_BASE_URL=http://localhost:3000

# Admin panel password (required in production for /admin/login)
ADMIN_PASSWORD=

# Secret used to sign/verify admin session cookies (required in production)
ADMIN_SESSION_SECRET=

# Optional admin session lifetime in seconds (defaults to 86400 / 24h)
ADMIN_SESSION_TTL_SECONDS=86400

# Required token used by admin review moderation API routes
ADMIN_TOKEN=

# Required recipient email address for incoming request notifications
MAIL_TO=

# Send customer order emails (true/false). Defaults to false when omitted.
SEND_CUSTOMER_EMAILS=false

# Optional Telegram integration (set both values together)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional SMTP configuration (required when SEND_CUSTOMER_EMAILS=true)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Optional sender/recipient addresses for specific email flows
LEADS_TO_EMAIL=
LEADS_FROM_EMAIL=

# Optional content CMS credentials
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=

# Optional legacy moderation token
REVIEW_MODERATION_TOKEN=

# Optional secret for signed order PDF access tokens (falls back to ADMIN_TOKEN when omitted)
ORDER_TOKEN_SECRET=

# Secret used to verify /api/payments/webhook signatures
PAYMENT_WEBHOOK_SECRET=

# Optional Baget Google Sheet catalog source
BAGET_SHEET_ID=1lH3zq_PrUQVbVa37P4WPn24Y60iAmmznnHP-soS7dYA
BAGET_SHEET_TAB=baget_catalog
BAGET_SHEET_CACHE_SECONDS=300
