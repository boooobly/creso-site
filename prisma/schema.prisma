generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  // Internal immutable identifier (UUID) to avoid coupling storage identity to public order numbers
  id              String   @id @default(uuid())
  number          String   @unique
  source          String
  status          String   @default("new")
  customerName    String?
  phone           String?
  email           String?
  comment         String?
  total           Int
  prepayRequired  Boolean  @default(false)
  prepayAmount    Int?
  paymentStatus   String   @default("unpaid")
  paymentProvider String?
  paymentRef      String?
  paidAmount      Int?
  paidAt          DateTime?
  payloadJson     Json
  quoteJson       Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Review {
  id          String   @id @default(cuid())
  name        String?
  isAnonymous Boolean  @default(false)
  rating      Int
  text        String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  moderatedAt DateTime?
  ipHash      String?
  userAgent   String?

  @@index([status, createdAt])
  @@index([rating])
}

model PortfolioItem {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  category         String
  shortDescription String?
  coverImage       String?
  galleryImages    Json     @default("[]")
  featured         Boolean  @default(false)
  published        Boolean  @default(false)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([category, published])
  @@index([sortOrder, createdAt])
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  type        String   @default("string")
  group       String   @default("general")
  label       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group])
}

model PageContent {
  id          String   @id @default(cuid())
  pageKey     String
  sectionKey  String
  fieldKey    String
  value       Json
  type        String   @default("string")
  label       String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([pageKey, sectionKey, fieldKey])
  @@index([pageKey, sectionKey, sortOrder])
}

model PricingEntry {
  id          String   @id @default(cuid())
  category    String
  subcategory String   @default("")
  key         String
  label       String
  value       Json
  unit        String?
  type        String   @default("number")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([category, subcategory, key])
  @@index([category, isActive, sortOrder])
}
